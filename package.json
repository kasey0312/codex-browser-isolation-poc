{
  "name": "langgraph-gemini-browser-isolation-poc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsup src/server/index.ts --format esm --out-dir dist/server --clean",
    "start": "node dist/server/index.js",
    "lint": "tsc --noEmit",
    "test": "npm run test:unit && npm run test:e2e:mock",
    "test:unit": "vitest run",
    "test:e2e:mock": "MOCK_RUNTIME=1 MOCK_BROWSER=1 vitest run --config vitest.e2e.config.ts tests/e2e/api.e2e.spec.ts",
    "test:e2e:ui": "playwright test",
    "install:browsers": "playwright install chromium",
    "smoke:real": "tsx scripts/smokeRealGemini.ts",
    "smoke:docker:mock": "DOCKER_BROWSER=1 MOCK_RUNTIME=1 tsx scripts/smokeDockerBrowser.ts",
    "smoke:docker:real": "DOCKER_BROWSER=1 MOCK_RUNTIME=0 tsx scripts/smokeDockerGemini.ts"
  },
  "dependencies": {
    "@langchain/core": "^1.1.36",
    "@langchain/google-genai": "^2.1.26",
    "@langchain/langgraph": "^1.2.6",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jose": "^6.0.10",
    "nanoid": "^5.1.5",
    "playwright": "^1.53.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2",
    "toml": "^3.0.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "jsdom": "^26.1.0",
    "supertest": "^7.1.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vitest": "^3.1.4"
  }
}
