PORT=3000
NODE_ENV=production
JWT_SECRET=replace-with-32-byte-random-secret
APP_BASE_URL=https://browser.example.com
VITE_API_BASE_URL=
CORS_ALLOWED_ORIGINS=https://browser.example.com
TRUST_PROXY=1
LOG_LEVEL=info
MOCK_RUNTIME=0
MOCK_BROWSER=0
DOCKER_BROWSER=1
DOCKER_BROWSER_IMAGE=seleniarm/standalone-chromium:latest
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=replace-with-real-key
